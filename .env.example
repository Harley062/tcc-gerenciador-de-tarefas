# Copy this file to .env and fill the secrets before running docker compose
# Example .env for local development

# JWT secret (change for production)
JWT_SECRET_KEY=your-secret-key-change-in-production

# Override Ollama endpoint if needed (default in compose is http://ollama:11434)
OLLAMA_ENDPOINT=http://ollama:11434

# Other envs
# DATABASE_URL=postgresql+asyncpg://taskmaster:taskmaster123@postgres/taskmaster
# REDIS_URL=redis://redis:6379
